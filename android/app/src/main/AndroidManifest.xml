<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Runtime-requested when user taps the bubble's "Voice input" entry. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Camera translate: snapshot-mode OCR on live camera feed. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Required for the foreground "mediaProjection" service that captures
         a single screen frame to feed into the bubble's "Scan screen" OCR. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:label="TransKey"
        android:name=".TransKeyApp"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep link: transkey://auth?token=... -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="transkey" android:host="auth"/>
            </intent-filter>
        </activity>

        <!-- Transparent receiver: PROCESS_TEXT/SEND from other apps.
             Translates text and shows result as a floating overlay,
             without opening the full app UI. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:label="@string/process_text_translate"
            android:icon="@mipmap/ic_launcher"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/ShareActivityTheme">
            <meta-data android:name="transkey.mode" android:value="translate"/>
            <!-- Share intent: receive text from other apps -->
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <!-- Process text: show in text selection menu.
                 Higher priority hints the system that this action is preferred. -->
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.PROCESS_TEXT"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity>

        <!-- Additional PROCESS_TEXT modes: each alias is a separate menu entry -->
        <activity-alias
            android:name=".ReplyAlias"
            android:targetActivity=".ShareActivity"
            android:exported="true"
            android:label="@string/process_text_reply"
            android:icon="@mipmap/ic_launcher">
            <meta-data android:name="transkey.mode" android:value="reply"/>
            <intent-filter android:priority="950">
                <action android:name="android.intent.action.PROCESS_TEXT"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <!-- Share menu target: "Share → TransKey: Reply" -->
            <intent-filter android:priority="950">
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".SummarizeAlias"
            android:targetActivity=".ShareActivity"
            android:exported="true"
            android:label="@string/process_text_summarize"
            android:icon="@mipmap/ic_launcher">
            <meta-data android:name="transkey.mode" android:value="summarize"/>
            <intent-filter android:priority="900">
                <action android:name="android.intent.action.PROCESS_TEXT"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <intent-filter android:priority="900">
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ExplainAlias"
            android:targetActivity=".ShareActivity"
            android:exported="true"
            android:label="@string/process_text_explain"
            android:icon="@mipmap/ic_launcher">
            <meta-data android:name="transkey.mode" android:value="explain"/>
            <intent-filter android:priority="800">
                <action android:name="android.intent.action.PROCESS_TEXT"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <intent-filter android:priority="800">
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".RefineAlias"
            android:targetActivity=".ShareActivity"
            android:exported="true"
            android:label="@string/process_text_refine"
            android:icon="@mipmap/ic_launcher">
            <meta-data android:name="transkey.mode" android:value="refine"/>
            <intent-filter android:priority="700">
                <action android:name="android.intent.action.PROCESS_TEXT"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <intent-filter android:priority="700">
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
        </activity-alias>

        <!-- Floating Bubble Service. specialUse subtype is mandatory on
             Android 14+ for FOREGROUND_SERVICE_SPECIAL_USE — without the
             PROPERTY_SPECIAL_USE_FGS_SUBTYPE property the system treats
             the FGS as misconfigured and aggressively reclaims it when
             the app is backgrounded (especially while another FGS like
             mediaProjection is also active). -->
        <service
            android:name=".BubbleService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating-translation-overlay-bubble" />
        </service>

        <!-- Transparent activity to request RECORD_AUDIO at runtime.
             A Service cannot request dangerous permissions directly, so the
             "Voice input" bubble entry routes through this activity, which
             then signals BubbleService to start the voice picker. -->
        <activity
            android:name=".MicPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/ShareActivityTheme" />

        <!-- Transparent activity that calls
             MediaProjectionManager.createScreenCaptureIntent() so the system
             can prompt the user once per session. Captured token is held in
             ScreenCaptureManager (in-memory only) and consumed by
             ScreenCaptureService for the bubble's "Scan screen" OCR flow. -->
        <activity
            android:name=".ScreenCapturePermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/ShareActivityTheme" />

        <!-- Foreground service that owns the MediaProjection + VirtualDisplay
             while capturing a single frame for OCR. The mediaProjection
             foregroundServiceType is mandatory for Android 14+ — otherwise
             startForegroundService throws SecurityException at capture time. -->
        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Accessibility Service: pastes reply into focused EditText of other apps -->
        <service
            android:name=".TransKeyAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- AdMob application ID — TransKey production.
             Ad UI is hidden client-side until /features.ads_enabled flips
             true (see FeatureFlags.adsEnabled), so users never see a
             no-fill error while AdMob review is pending. Debug builds use
             a TEST ad unit at request time (RewardedAdService); the prod
             app ID + test unit combo is allowed by AdMob and avoids
             invalid-traffic risk from developer devices. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-4388572340562895~4234387926" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required on Android 11+ for SpeechRecognizer.isRecognitionAvailable
             to return true — otherwise the system reports no recognizer even
             when one is installed. -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
        <!-- url_launcher needs this on Android 11+ to launch http/https URLs -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="http"/>
        </intent>
    </queries>
</manifest>
