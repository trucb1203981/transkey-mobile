    <Row>
        <Key android:codes="-1" android:keyLabel="⇧" android:keyWidth="13%p" android:isModifier="true"/>
        <Key android:codes="1079" android:keyLabel="з" android:keyWidth="7%p"/>
        <Key android:codes="1095" android:keyLabel="ч" android:keyWidth="7%p"/>
        <Key android:codes="1094" android:keyLabel="ц" android:keyWidth="7%p"/>
        <Key android:codes="1074" android:keyLabel="в" android:keyWidth="7%p"/>
        <Key android:codes="1073" android:keyLabel="б" android:keyWidth="7%p"/>
        <Key android:codes="1085" android:keyLabel="н" android:keyWidth="7%p"/>
