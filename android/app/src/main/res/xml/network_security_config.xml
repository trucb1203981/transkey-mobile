<?xml version="1.0" encoding="utf-8"?>
<!--
  Production network policy — cleartext (HTTP) is denied for every host,
  no exceptions. Release builds against https://api.transkey.app only.

  Local development needs to hit the laptop's API over plain HTTP on the
  LAN; that allowance lives in `network_security_config_debug.xml` and is
  wired in via `android/app/src/debug/AndroidManifest.xml`, so it only
  applies to debug builds and never ships to the Play Store.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="false" />
</network-security-config>
