<?xml version="1.0" encoding="utf-8"?>
<!--
    Korean Chunjiin (천지인) 10-key. 7 consonant group keys (multi-tap cycles the
    group, e.g. ㄱ->ㅋ->ㄲ) + 3 vowel-stroke keys · / ㅡ / ㅣ. Consonant key codes
    are the first jamo's code point (mapped to a group in TransKeyIME.chunGroup);
    the dot uses ㆍ (U+318D = 12685). ChunjiinComposer turns the strokes into
    vowels and feeds HangulComposer for block building. 3 columns x 5 rows.
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="31%p"
    android:keyHeight="42dp"
    android:horizontalGap="2.0%p"
    android:verticalGap="9dp">

    <Row>
        <Key android:codes="12593" android:keyLabel="ㄱ ㅋ"/>
        <Key android:codes="12596" android:keyLabel="ㄴ ㄹ"/>
        <Key android:codes="12599" android:keyLabel="ㄷ ㅌ"/>
    </Row>

    <Row>
        <Key android:codes="12610" android:keyLabel="ㅂ ㅍ"/>
        <Key android:codes="12613" android:keyLabel="ㅅ ㅎ"/>
        <Key android:codes="12616" android:keyLabel="ㅈ ㅊ"/>
    </Row>

    <Row>
        <Key android:codes="12615" android:keyLabel="ㅇ ㅁ"/>
        <Key android:codes="12685" android:keyLabel="·"/>
        <Key android:codes="12641" android:keyLabel="ㅡ"/>
    </Row>

    <Row>
        <Key android:codes="-201" android:keyLabel="\?123"/>
        <Key android:codes="12643" android:keyLabel="ㅣ"/>
        <Key android:codes="-5" android:keyLabel="⌫" android:isRepeatable="true"/>
    </Row>

    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-301" android:keyWidth="24%p"/>
        <Key android:codes="32" android:keyLabel="space" android:keyWidth="50%p"/>
        <Key android:codes="-4" android:keyWidth="24%p"/>
    </Row>
</Keyboard>
