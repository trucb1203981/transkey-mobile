<?xml version="1.0" encoding="utf-8"?>
<!-- Number pad - shown for numeric / phone / datetime fields. 5 columns:
     a symbol column (left), the 1-9/0 keypad (middle), and a function
     column (right: backspace / parens / enter). Symbols cover both number
     (- + , .) and phone (* # parens) entry; the field's own filter drops any
     char it doesn't accept. Matches the symbols layer's 40dp height + 10dp
     gap so the IME window doesn't resize on field switch. -->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="18.4%p"
    android:keyHeight="40dp"
    android:horizontalGap="1.2%p"
    android:verticalGap="10dp">

    <Row>
        <Key android:codes="45" android:keyLabel="-"/>
        <Key android:codes="49" android:keyLabel="1"/>
        <Key android:codes="50" android:keyLabel="2"/>
        <Key android:codes="51" android:keyLabel="3"/>
        <Key android:codes="-5" android:keyLabel="⌫" android:isRepeatable="true"/>
    </Row>

    <Row>
        <Key android:codes="43" android:keyLabel="+"/>
        <Key android:codes="52" android:keyLabel="4"/>
        <Key android:codes="53" android:keyLabel="5"/>
        <Key android:codes="54" android:keyLabel="6"/>
        <Key android:codes="40" android:keyLabel="("/>
    </Row>

    <Row>
        <Key android:codes="44" android:keyLabel=","/>
        <Key android:codes="55" android:keyLabel="7"/>
        <Key android:codes="56" android:keyLabel="8"/>
        <Key android:codes="57" android:keyLabel="9"/>
        <Key android:codes="41" android:keyLabel=")"/>
    </Row>

    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="46" android:keyLabel="."/>
        <Key android:codes="42" android:keyLabel="*"/>
        <Key android:codes="48" android:keyLabel="0"/>
        <Key android:codes="35" android:keyLabel="#"/>
        <Key android:codes="-4" android:keyLabel="↩"/>
    </Row>
</Keyboard>
