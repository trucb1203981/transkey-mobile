<?xml version="1.0" encoding="utf-8"?>
<!--
    onAccessibilityEvent in TransKeyAccessibilityService is a no-op — we
    only use this service for action-on-demand calls (replaceFocusedText,
    readFocusedText) triggered from the Reply UI, not for event-driven
    observation. Subscribe to the minimum event (typeWindowStateChanged
    fires on foreground-app change, not on every keystroke / scroll /
    focus change) so the system doesn't wake the service hundreds of
    times per minute while the user is typing in another app.

    flagIncludeNotImportantViews stays so findFocusedEditable can locate
    Jetpack Compose / React Native text inputs (they're often marked
    "not important for accessibility" by their frameworks).
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagIncludeNotImportantViews"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="app.transkey.mobile.MainActivity" />
