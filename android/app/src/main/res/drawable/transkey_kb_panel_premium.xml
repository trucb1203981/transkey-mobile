<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid Glass keyboard panel fill: opaque aurora-dark top-lit gradient with
     lightly rounded TOP corners + a light hairline border, mirroring the
     bubble pickers' Glass.panel() treatment (BubbleStyle.kt) — same "fake
     glass" (opaque tint + specular + border) since the IME floats over
     arbitrary app content, not the app's own aurora backdrop. Applies to ALL
     users now (see TransKeyIME.applyPremiumChrome); the brand-gradient accent
     bar on the top edge (drawn by SuggestionStripView, clipped to these same
     rounded corners) stays the paid-only differentiator. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#FF2C2A35"
        android:endColor="#FF14121F" />
    <corners
        android:topLeftRadius="12dp"
        android:topRightRadius="12dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
    <stroke
        android:width="1dp"
        android:color="#29FFFFFF" />
</shape>
