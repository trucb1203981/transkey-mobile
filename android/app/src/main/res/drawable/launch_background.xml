<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash: brand-dark background + centered logo, so cold start shows
     the app identity instead of a plain (black, in dark mode) window while the
     Flutter engine boots. Same in light/dark to avoid a color flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0B1020" />
        </shape>
    </item>
    <item>
        <bitmap android:gravity="center" android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
