<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Debug-only override: swap the strict production network policy
         (@xml/network_security_config, denies all cleartext) for the LAN
         whitelist so `flutter run` against the laptop's local API works.
         Release builds inherit the main manifest's reference unchanged. -->
    <application
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:networkSecurityConfig" />
</manifest>
